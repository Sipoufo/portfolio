# ─── Deployment ───────────────────────────────────────────────────────────
# Name of the Docker network used by Nginx Proxy Manager. Find with:
#   docker network ls
NPM_NETWORK=nginx-proxy-manager_default

# Public origin (used by CORS and by the SPA to compute absolute links).
PUBLIC_ORIGIN=https://portfolio.printmarksgraphics.cloud
CORS_ORIGINS=https://portfolio.printmarksgraphics.cloud

# ─── Frontend (build-time, baked into the SPA) ────────────────────────────
VITE_BASE_PATH=/
VITE_API_BASE_URL=/api

# ─── Backend ──────────────────────────────────────────────────────────────
NODE_ENV=production
LOG_LEVEL=info
PORT=3001

# JWT secret used to sign auth tokens (admin). Generate with:
#   openssl rand -base64 48
JWT_SECRET=change-me-with-openssl-rand-base64-48

# First-run admin credentials. Used only by the seed script.
ADMIN_EMAIL="[email protected]"
ADMIN_PASSWORD=change-me

# ─── Database (Postgres) ──────────────────────────────────────────────────
POSTGRES_USER=portfolio
POSTGRES_PASSWORD=change-me
POSTGRES_DB=portfolio

# Connection string used by Prisma.
# - Local dev (running `pnpm dev` on the host)        → host = localhost
# - In production / docker compose for the api ctr    → host = portfolio-db
#   (the docker-compose.yml overrides DATABASE_URL on the api service to
#    point at the container hostname automatically).
DATABASE_URL=postgresql://portfolio:change-me@localhost:5432/portfolio?schema=public
