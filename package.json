{
  "name": "portfolio",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@9.12.0",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "pnpm -r --parallel --filter \"./packages/*\" dev",
    "build": "pnpm -r --filter \"./packages/*\" build",
    "lint": "pnpm -r --filter \"./packages/*\" lint",
    "type-check": "pnpm -r --filter \"./packages/*\" type-check",
    "format": "prettier --write \"packages/**/*.{ts,tsx,json,md,css}\"",
    "format:check": "prettier --check \"packages/**/*.{ts,tsx,json,md,css}\""
  },
  "devDependencies": {
    "prettier": "^3.3.3",
    "typescript": "^5.6.3"
  }
}
